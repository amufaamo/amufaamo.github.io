---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const blogEntries = await getCollection('blog');
const workEntries = await getCollection('works');

// order順にソート（指定がない場合は後ろに）
const sortedWorks = workEntries.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Layout title="Masakazu Ishikawa Portfolio">
  <main class="mx-auto max-w-6xl px-4 py-12 font-sans">
    <header class="mb-16 text-center">
      <h1 class="mb-4 text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 sm:text-5xl">
        Masakazu Ishikawa Portfolio
      </h1>
    </header>

    <section class="mb-16">
      <h2 class="mb-8 text-2xl font-semibold text-zinc-800 dark:text-zinc-200">
        Works
      </h2>
      <div class="flex flex-col gap-6">
        {
          sortedWorks.map((work) => (
            <ProjectCard
              title={work.data.title}
              thumbnail={work.data.thumbnail}
              link={work.data.link}
            />
          ))
        }
      </div>
    </section>

    {blogEntries.length > 0 && (
      <section>
        <h2 class="mb-6 text-2xl font-semibold text-zinc-800 dark:text-zinc-200">
          Latest Blog Posts
        </h2>
        <div class="prose prose-zinc dark:prose-invert">
          <ul class="space-y-3">
            {blogEntries.map((post) => (
              <li>
                <a href={`${import.meta.env.BASE_URL}blog/${post.id}`} class="no-underline hover:underline text-blue-600 dark:text-blue-400">
                  {post.data.title}
                </a>
                {post.data.pubDate && (
                  <span class="ml-2 text-sm text-zinc-500">
                    - {post.data.pubDate.toLocaleDateString('ja-JP')}
                  </span>
                )}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}
  </main>

  <footer class="mt-auto border-t border-zinc-200 py-8 text-center text-zinc-500 dark:border-zinc-800 dark:text-zinc-400">
    <p>&copy; {new Date().getFullYear()} amufaamo. All rights reserved.</p>
  </footer>
</Layout>

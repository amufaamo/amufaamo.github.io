---
interface Props {
  title: string;
  thumbnail: string;
  link: string;
}

const { title, thumbnail, link } = Astro.props;
---

<a href={link} class="group flex flex-col sm:flex-row overflow-hidden rounded-xl bg-white shadow-sm transition-all hover:-translate-y-1 hover:shadow-md dark:bg-zinc-900 border border-zinc-100 dark:border-zinc-800">
  <div class="aspect-video w-full sm:w-64 md:w-80 shrink-0 overflow-hidden bg-zinc-100 dark:bg-zinc-800">
    <img
      src={thumbnail}
      alt={title}
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
    />
  </div>
  <div class="flex flex-col justify-center p-6">
    <h3 class="text-xl font-bold text-zinc-900 transition-colors group-hover:text-blue-600 dark:text-zinc-100 dark:group-hover:text-blue-400">
      {title}
    </h3>
    <p class="mt-2 text-zinc-600 dark:text-zinc-400">
      クリックして作品の詳細（GitHub Pages）を見る
    </p>
  </div>
</a>
